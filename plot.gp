set grid
set key outside

set title 'Preys and predators'
set xlabel 'step'
set ylabel 'population'
plot $data every ::1 using 1:2 with lines title 'preys', \
     $data every ::1 using 1:3 with lines title 'predators'
pause -1

set title 'Phase portrait'
set xlabel 'preys x'
set ylabel 'predators y'
plot $data every ::1 using 2:3 with lines title 'orbit'
pause -1

set title 'First integral H'
set xlabel 'step'
set ylabel 'H'
plot $data every ::1 using 1:4 with lines title 'H'
pause -1
